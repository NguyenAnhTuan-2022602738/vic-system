# AI Service Environment
# Copy this to .env and fill in values

# App
APP_NAME=VIC AI Service
APP_VERSION=0.1.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Model
MODEL_PATH=models/active_model.pt

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Adjustment parameters
ALPHA=0.3
BETA=0.2
